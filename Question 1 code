import java.util.*;

public class GraphRepresentation {
    public static void main(String[] args) {

        // Define 4 vertices
        int[] vertices = {0, 1, 2, 3};

        // 1. Adjacency Matrix Implementation
        // A 4x4 matrix where matrix[i][j] = 1 indicates an edge exists.
        int[][] adjMatrix = new int[4][4];

        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                if (i != j) {
                    adjMatrix[i][j] = 1;
                } else {
                    adjMatrix[i][j] = 0;
                }
            }
        }

        // 2. Adjacency List Implementation
        // Using a HashMap where each key is a vertex and its value is a list of neighbors.
        HashMap<Integer, ArrayList<Integer>> adjList = new HashMap<>();

        for (int v : vertices) {
            ArrayList<Integer> neighbors = new ArrayList<>();

            for (int u : vertices) {
                if (u != v) {
                    neighbors.add(u);
                }
            }

            adjList.put(v, neighbors);
        }

        // Print Adjacency Matrix
        System.out.println("--- Adjacency Matrix (4x4) ---");

        for (int[] row : adjMatrix) {
            System.out.println(Arrays.toString(row));
        }

        // Print Adjacency List
        System.out.println("\n--- Adjacency List ---");

        for (Map.Entry<Integer, ArrayList<Integer>> entry : adjList.entrySet()) {
            System.out.println("Vertex " + entry.getKey() + ": " + entry.getValue());
        }
    }
}
