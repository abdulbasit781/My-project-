import java.util.*;

public class TopologicalSort {

    // Function for Topological Sort
    public static List<String> topologicalSort(Map<String, List<String>> graph) {

        Set<String> visited = new HashSet<>();
        Stack<String> stack = new Stack<>();

        // DFS function
        for (String vertex : graph.keySet()) {
            if (!visited.contains(vertex)) {
                dfs(vertex, graph, visited, stack);
            }
        }

        // Reverse stack to get topological order
        List<String> result = new ArrayList<>();

        while (!stack.isEmpty()) {
            result.add(stack.pop());
        }

        return result;
    }

    // DFS Helper Method
    public static void dfs(String node,
                           Map<String, List<String>> graph,
                           Set<String> visited,
                           Stack<String> stack) {

        visited.add(node);

        // Visit all neighbors
        for (String neighbor : graph.get(node)) {
            if (!visited.contains(neighbor)) {
                dfs(neighbor, graph, visited, stack);
            }
        }

        // Push after visiting descendants
        stack.push(node);
    }

    public static void main(String[] args) {

        // Example Graph Structure
        // A -> B, A -> C, B -> D, C -> D

        Map<String, List<String>> graphData = new HashMap<>();

        graphData.put("A", Arrays.asList("B", "C"));
        graphData.put("B", Arrays.asList("D"));
        graphData.put("C", Arrays.asList("D"));
        graphData.put("D", new ArrayList<>());

        List<String> order = topologicalSort(graphData);

        System.out.println("Topological Sort Order: " +
                String.join(" -> ", order));
    }
}
