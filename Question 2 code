import java.util.*;

public class PakistaniChange {

    // Function to calculate change breakdown
    public static HashMap<Integer, Integer> calculatePakistaniChange(int amount) {

        // Denominations in descending order for Greedy approach
        int[] denominations = {5000, 1000, 500, 100, 50, 20, 10, 5, 2, 1};

        HashMap<Integer, Integer> changeBreakdown = new LinkedHashMap<>();

        int tempAmount = amount;

        for (int coin : denominations) {
            if (tempAmount >= coin) {
                int count = tempAmount / coin;
                tempAmount %= coin;

                changeBreakdown.put(coin, count);
            }
        }

        return changeBreakdown;
    }

    public static void main(String[] args) {

        // Execution for Rs. 1988
        int totalRs = 1988;

        HashMap<Integer, Integer> result = calculatePakistaniChange(totalRs);

        System.out.println("Total Amount: Rs. " + totalRs);
        System.out.println("-------------------------");

        for (Map.Entry<Integer, Integer> entry : result.entrySet()) {

            int note = entry.getKey();
            int count = entry.getValue();

            String label = (note >= 10) ? "Notes" : "Coins";

            System.out.printf("Rs. %-4d %-5s : %d%n", note, label, count);
        }
    }
}
